      "PredictionResponse": {
        "entities": [
          {
            "word": "string (e.g. 'Aspirin')",
            "tag": "string (e.g. 'MEDICATION')",
            "confidence": "float",
            "start": "int (optional)",
            "end": "int (optional)"
          }
        ]
      }
    },
    "models": {
      "DualStreamFusionNER": {
        "type": "Bio_ClinicalBERT + EasyOCR",
        "model_path": "backend/models/saved_weights/dual_stream_ner_best.pth",
        "hf_repo_id": "abhshkgtm19/Healthcare-NLP-Models"
      }
    }
  },
  "required_actions": {
    "frontend": "Ensure text submissions use JSON body for /predict and FormData for /predict-image. Parse 'entities' array for XAI DOM highlighting.",
    "ml": "Maintain spatial OCR bounding boxes and ensure token offsets map correctly in evaluate_fusion.py."
  }
}
