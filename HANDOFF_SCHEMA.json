{
  "handoff_id": "INIT_SYNC_HEALTHCARE",
  "source_role": "Integration QA Specialist",
  "target_roles": ["Lead ML/Backend Engineer", "Lead Frontend Engineer"],
  "payload": {
    "api_endpoints": {
      "predict": "/predict",
      "health": "/health",
      "model_info": "/model-info"
    },
    "input_schema": {
      "PredictionRequest": {
        "text": "string (required, min_length=1, max_length=5000)",
        "model_choice": "string (default='fast', options: 'fast' | 'accurate')"
      }
    },
    "output_schema": {
      "PredictionResponse": {
        "prediction": "string (medical specialty label)",
        "confidence": "float",
        "explanation": "string (department routing rationale)",
        "word_importances": "Dict[string, float]",
        "model_used": "string",
        "error": "Optional[string]"
      }
    },
    "models": {
      "fast": {
        "type": "SGDClassifier (Scikit-Learn)",
        "model_path": "backend/models/clinical_text_classifier.pkl",
        "vectorizer_path": "backend/models/tfidf_vectorizer.pkl"
      },
      "accurate": {
        "type": "DistilBERT (Transformers)",
        "model_path": "backend/models/distilbert/",
        "hf_repo_id": "abhshkgtm19/MedVision-NLP-Models"
      }
    }
  },
  "required_actions": {
    "frontend": "Ensure forms submit JSON body with 'text' and 'model_choice' fields to POST /predict",
    "ml": "Run project_sync_audit.py before next deployment to verify Pydantic schemas match"
  }
}
