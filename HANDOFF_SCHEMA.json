{
  "handoff_id": "SYNC_MEDICAL_CLASSIFICATION_AND_RAG",
  "source_role": "Integration QA Specialist",
  "target_roles": ["Lead ML/Backend Engineer", "Lead Frontend Engineer"],
  "payload": {
    "api_endpoints": {
      "predict": "/predict",
      "predict_image": "/predict-image (DEPRECATED)",
      "predict_rag": "/predict-rag",
      "chat": "/chat",
      "health": "/health",
      "metrics": "/metrics",
      "monitoring": "/monitoring"
    },
    "input_schema": {
      "PredictionRequest": {
        "text": "string (required, min_length=1, max_length=5000)"
      },
      "ChatRequest": {
        "messages": "List[{role: 'user' | 'assistant', content: string}]"
      }
    },
    "output_schema": {
      "AnalysisResponse": {
        "specialty": "string",
        "confidence": "float",
        "word_attributions": [
          {
            "word": "string",
            "score": "float"
          }
        ],
        "rag_response": {
          "answer": "string",
          "sources": "List[{content: string, source: string, layer: string, relevance_score: float}]",
          "interceptor_flag": "string (optional - e.g. EMERGENCY, PEDIATRIC_DOSING)"
        },
        "error": "string (optional)"
      }
    },
    "models": {
      "Bio_ClinicalBERT_Classifier": {
        "type": "SequenceClassification + Captum XAI",
        "model_path": "backend/models/bio_clinicalBERT/bio_clinicalBERT_model.pth",
        "hf_repo_id": "abhshkgtm19/medvision-models"
      },
      "Dual_Layer_VectorDB": {
        "type": "ChromaDB + all-MiniLM-L6-v2 Embeddings",
        "layers": ["Action Layer (Indian Guidelines)", "Foundation Layer (Global Standards)"]
      },
      "Generative_LLM": {
        "type": "Google Gemini 2.5 Flash",
        "role": "Medical Assistant / Safety Enforcer"
      }
    }
  },
  "required_actions": {
    "frontend": "Parse 'word_attributions' array for Captum XAI highlighting. Parse 'rag_response.sources' to display citation badges. Handle 'interceptor_flag' to render red emergency alert banners.",
    "ml": "Maintain eager singleton loading of models, ChromaDB, and GenAI clients. Never bypass Regex Safety Interceptors before LLM generation."
  }
}
